extends ../layout.pug

block metadata
    title Crear publicacion

block content
    body
        div(class="flex justify-center my-5")
            a(href="/")
                button(type="button" class="bg-white text-[20px] px-3 py-1 hover:bg-orange-400 hover:font-bold hover:text-white border-1 border-gray-400 cursor-pointer") Volver a Home

        .formContent(class="bg-orange-100 flex flex-col justify-center mx-100")
            div(class="mx-10 mt-5 mb-10")
                form(action="/subirPost/", method="post" name="postPublicForm" enctype="multipart/form-data") 
                    label(for="titulo" class="text-[30px] font-bold") Titulo(Obligatorio)
                    input(type="text", name="titulo" id="titulo" class="bg-white w-full text-[15px] mt-2 p-1" placeholder="Que no este vacio, Empezar con mayuscula con o sin tilde y maximo de 100 caracteres")

                    div(class="mt-3")
                        label(for="descripcion" class="text-[30px] font-bold") Descripcion(Opcional) 
                        textarea(name="descripcion" id="descripcion" class="block bg-white text-[15px] px-1" rows="10" cols="140")

                    div#img_options(class="mt-10 flex justify-center gap-4")
                        input(type="file" name="img_file" id="img_file" class="hidden" multiple accept="image/*")
                        label(for="img_file" id="img_file" class="text-[30px] font-bold bg-orange-300 px-7 cursor-pointer") Click aqui para cargar sus imagenes 
                    #preview_text(class="mt-10 hidden text-[25px] text-center")

                    #preview(class="mt-5 hidden grid grid-cols-2 gap-3 w-fit")

                    div(class="mt-10 block")
                        label(for="etiquetas" class="text-[30px] font-bold")  Agregar etiquetas a la publicacion
                        input(type="text", name="etiquetas" id="etiquetas" class="bg-white w-full text-[15px] mt-2 p-1" placeholder="Maximo 5 etiquetas, y un maximo de 25 caracteres cada una")

                    div(class="flex justify-center mt-5")
                        button(type="submit" class="bg-green-400 text-2xl font-bold px-10 py-2 hover:bg-green-600 hover:text-white") Publicar 
    
    script(src="./script/post/post.js" defer) 
        

            
        