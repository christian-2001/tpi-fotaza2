extends ../layout.pug

block metadata
    title Registrarse

block metadata
    title Registrarse

block content
    .login_content(class="bg-gray-200 flex flex-col items-center justify-center mx-110 mt-20")
        p(class="text-4xl font-bold block mt-5") Ingrese los siguientes datos

        form(action="", method="get")
            div(class="flex flex-col mt-10 mb-10")
                input(type="text", name="nombre" id="nombre" placeholder="Nombre" class="text-2xl text-gray-400 font-bold pt-2 pb-2 pl-4 bg-white block w-200 mb-2")
                input(type="text", name="apellido" id="apellido" placeholder="Apellido" class="text-2xl text-gray-400 font-bold  pt-2 pb-2 pl-4 bg-white block w-200 mb-2")
                input(type="text", name="anio_nacimiento" id="anio_nacimiento" placeholder="Fecha y año de nacimiento" class="text-2xl text-gray-400 font-bold  pt-2 pb-2 pl-4 bg-white block w-200 mb-2")
                input(type="text", name="genero" id="genero" placeholder="Genero" class="text-2xl text-gray-400 font-bold  pt-2 pb-2 pl-4 bg-white block w-200 mb-2")
                input(type="text", name="país" id="país" placeholder="País de residencia" class="text-2xl text-gray-400 font-bold  pt-2 pb-2 pl-4 bg-white block w-200 mb-2")
                input(type="text", name="mail" id="mail" placeholder="Mail" class="text-2xl text-gray-400 font-bold pt-2 pb-2 pl-4 bg-white block w-200 mb-2")
                input(type="text", name="dni" id="dni" placeholder="DNI" class="text-2xl text-gray-400 font-bold pt-2 pb-2 pl-4 bg-white block w-200 mb-2")
                input(type="text", name="tipo_dni" id="tipo_dni" placeholder="Tipo DNI" class="text-2xl text-gray-400 font-bold pt-2 pb-2 pl-4 bg-white block w-200")
            div(class="flex justify-center mb-5")
                a(href="/login" class="hover:text-blue-400") 
                    p(class="text-2xl") Inicia sesion si ya tiene una cuenta
            div(class="flex justify-center mb-5")
                button(type="submit" class="border-none pl-20 pr-20 pt-2 pb-2 text-3xl bg-white font-bold hover:bg-orange-500 hover:text-white") Continuar
                            