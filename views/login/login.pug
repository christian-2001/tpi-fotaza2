extends ../layout.pug

block metadata
    link(rel="stylesheet", href="./style/output.css")
    title Iniciar Sesion

block content
    body
        .login_content(class="bg-gray-200 flex flex-col items-center justify-center mx-110 mt-20")
            p(class="text-4xl font-bold block mt-5") Accede a tu cuenta
    
            form(action="", method="get")
                div(class="flex flex-col mt-10 mb-10")
                    input(type="text", name="mail_or_user" placeholder="Mail o nombre de usuario" class="text-2xl text-gray-400 font-bold pt-2 pb-2 pl-4 bg-white block w-200 mb-2")
                    input(type="text", name="password" placeholder="Contraseña" class="text-2xl text-gray-400 font-bold pt-2 pb-2 pl-4 bg-white block w-200")
                div(class="flex justify-center mb-5")
                    a(href="/registrer" class="hover:text-orange-500") 
                        p(class="text-2xl") Click aqui para crearse una cuenta
                div(class="flex justify-center mb-5")
                    button(type="submit" class="border-none pl-20 pr-20 pt-2 pb-2 text-3xl bg-white font-bold hover:bg-blue-500 hover:text-white") Acceder  