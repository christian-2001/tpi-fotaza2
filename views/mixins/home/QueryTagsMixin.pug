mixin tagsQuery(queryResult = undefined)
    
    div(class="flex justify-center mt- mb-6")
        a(href="/subirPost")
            button(type="button" class="bg-white text-[20px] px-3 py-1 hover:bg-orange-400 hover:font-bold hover:text-white border-1 border-gray-400 cursor-pointer") Crear publicación

    div(class="flex justify-center text-[35px] font-bold")
        p Resultados de Busqueda:

    if queryResult.length === 1
        div(class="flex flex-col justify-center mt-10 mb-20 mx-150")
            div(class="grid bg-white")
                .post(class="bg-white border-1 border-gray-400 rounded-[10px] p-3 hover:outline-3 hover:outline-orange-400 hover:opacity-80 h-fit")
                    .post_usuario(class="text-center text-[20px]")
                        p
                            | Publicado por 
                            a(href=`/usuarioPerfil/${queryResult[0].Usuario.id_usuario}/posts` class="hover:font-bold") #{queryResult[0].Usuario.nombre_usuario}
                            |   - #{queryResult[0].fh_publicacion.toLocaleDateString()} - #{queryResult[0].fh_publicacion.toLocaleTimeString()}
                    .post_titulo(class="mt-3 text-center text-3xl font-bold hover:text-black/50")
                        a.url_post(href=`/post/${queryResult[0].id_post}/${queryResult[0].Imagens.length - queryResult[0].Imagens.length}` class="cursor-pointer hover:text-3xl")
                            h1 #{queryResult[0].titulo}
                    .post_descripcion(class="mt-5 text-1xl")
                        p #{queryResult[0].descripcion}
                    .post_etiquetas(class="mt-2 inline-block")
                        p Etiquetas:
                            form(action="/buscar" method="get")
                                each tags in queryResult[0].Etiqueta
                                    label(for=`${tags.nom_etiqueta}`)
                                        button(type="submit" name="etiqueta" id="etiqueta" value=`${tags.nom_etiqueta}` class="cursor-pointer hover:text-blue-500/50 font-bold text-blue-600 mr-[3px]") ##{tags.nom_etiqueta}
                    .post_imagenes(class="bg-gray-400 border-[1px] border-gray-400/50")
                        if queryResult[0].Imagens.length > 1
                            .imagenes(class="grid grid-cols-2 gap-[1px]")
                                each post_img in queryResult[0].Imagens
                                    .img_elem
                                        img(src=`${post_img.img_path}`)
                        else if queryResult[0].Imagens.length == 1
                            .imagenes(class="grid grid-cols-1")
                                each post_img in queryResult[0].Imagens
                                    .img_elem
                                        img(src=`${post_img.img_path}`)

    else if queryResult.length > 1
        div(class="grid grid-cols-2 mt-10 mb-20 mx-60 gap-4")
            each post in queryResult
                .post(class="bg-white border-1 border-gray-400 rounded-[10px] p-3 hover:outline-3 hover:outline-orange-400 hover:opacity-80")
                    .post_usuario(class="text-center text-[20px]")
                        p
                            | Publicado por 
                            a(href=`/usuarioPerfil/${post.Usuario.id_usuario}/posts` class="hover:font-bold") #{post.Usuario.nombre_usuario}
                            |  - #{post.fh_publicacion.toLocaleDateString()} - #{post.fh_publicacion.toLocaleTimeString()}
                    .post_titulo(class="mt-3 text-center text-3xl font-bold hover:text-black/50")
                        a.url_post(href=`/post/${post.id_post}/${post.Imagens.length - post.Imagens.length}`)
                            h1 #{post.titulo}
                    .post_descripcion(class="mt-5 text-1xl")
                        p #{post.descripcion}
                    .post_etiquetas(class="mt-2 inline-block")
                        p Etiquetas:
                            form(action="/buscar" method="get")
                                each tags in post.Etiqueta
                                    label(for=`${tags.nom_etiqueta}`)
                                        button(type="submit" name="etiqueta" id="etiqueta" value=`${tags.nom_etiqueta}` class="cursor-pointer hover:text-blue-500/50 font-bold text-blue-600 mr-[3px]") ##{tags.nom_etiqueta}
                    .post_imagenes(class="bg-gray-400 border-[1px] border-gray-400/50")
                        if post.Imagens.length > 1
                            .imagenes(class="grid grid-cols-2 gap-[1px]")
                                each post_img in post.Imagens
                                    .img_elem
                                        img(src=`${post_img.img_path}`)
                        else if post.Imagens.length == 1
                            .imagenes(class="grid grid-cols-1")
                                each post_img in post.Imagens
                                    .img_elem
                                        img(src=`${post_img.img_path}`)
    else
        div(class="ml-[3rem] text-[35px] font-bold text-red-500 text-center mt-10")
            p No se ha obtenido resultados
