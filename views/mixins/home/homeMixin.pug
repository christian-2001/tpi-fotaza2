mixin home(postTag = undefined)
    body(class="bg-gray-200/70")

        .bar_naranja(class="bg-orange-400 px-10 text-2xl h-15 flex justify-between items-center")
            a(href="/") 
                p(class="cursor-pointer hover:bg-cyan-400 hover:text-white") Home
                
            form(action="/buscar", method="get" id="form_buscar") 
                .foto_buscador(class="ml-66 items-center")
                    if postTag
                        input(class="bg-white text-[20px] p-2 mr-10 w-xl rounded-md focus:outline-orange-300" type="text" name="buscador" id="buscador" value=`#${postTag}`) 
                    else
                        input(class="bg-white text-[20px] p-2 mr-10 w-xl rounded-md focus:outline-orange-300" type="text" name="buscador" id="buscador") 
                    button#filtros(type="button" class="bg-white p-2 text-[20px] rounded-md hover:bg-amber-400") Filtrar por
            .user(class="flex gap-10")
                p(class="py-2") Notificaciones 
                a(href="/login" class="py-2 hover:bg-green-500 hover:text-white") 
                    p Iniciar Sesion 
           
