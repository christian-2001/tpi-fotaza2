                                    if cant_valorizaciones > 0
                                        p(class="text-center") #{cant_valorizaciones}
                                    else
                                        p(class="text-center") Ninguna
                                        
                                div(class="py-3")
                                    p Promedio de valorizaciones
                                    if prom_valorizacion > 0
                                        p(class=" text-center") 
                                            while n < prom_valorizacion
                                                | &#11088;
                                                - n++
                                    else
                                        p(class=" text-center") Ninguna
                            .botones(class="bg-orange-600/85 py-5 px-20 flex justify-center")
